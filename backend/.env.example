# Server Configuration
PORT=3000
NODE_ENV=production
API_URL=https://your-domain.com

# MongoDB
MONGODB_URI=mongodb://your-mongodb-connection-string

# JWT Authentication (use strong random secrets in production - at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# FIREBASE REMOVED - Uncomment when adding mobile app support
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Google OAuth (for web authentication)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-domain.com/api/web/auth/google/callback

# Frontend URL (for OAuth redirect)
FRONTEND_URL=https://your-frontend-domain.com

# External APIs (USDA FoodData Central)
USDA_API_KEY=your-usda-api-key
USDA_API_URL=https://api.nal.usda.gov/fdc/v1

# AI (Google Gemini)
GEMINI_API_KEY=your-gemini-api-key

# Image Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
