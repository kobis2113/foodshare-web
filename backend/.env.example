# Server
PORT=3000
NODE_ENV=development

# MongoDB (Local - as required by course)
MONGODB_URI=mongodb://localhost:27017/foodshare

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Firebase Admin (for Android app auth verification)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/web/auth/google/callback

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:5173

# External API (Nutrition)
NUTRITION_API_KEY=your-nutrition-api-key
NUTRITION_API_URL=https://api.calorieninjas.com/v1/nutrition

# Image Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
